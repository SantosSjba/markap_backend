// Catálogos: tipos de documento y de propiedad

model DocumentType {
  id       String  @id @default(uuid())
  code     String  @unique
  name     String
  length   Int?    @map("length")
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clients Client[]
  agents  Agent[]

  @@map("document_types")
}

model PropertyType {
  id       String  @id @default(uuid())
  name     String
  code     String  @unique
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  properties Property[]

  @@map("property_types")
}
