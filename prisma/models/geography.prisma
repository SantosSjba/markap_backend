// Ubigeo Perú

model Department {
  id   String @id
  name String

  provinces Province[]

  @@map("departments")
}

model Province {
  id           String @id
  departmentId String @map("department_id")
  name         String

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  districts  District[]

  @@index([departmentId])
  @@map("provinces")
}

model District {
  id         String @id
  provinceId String @map("province_id")
  name       String

  province   Province   @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  addresses  Address[]
  properties Property[]

  @@index([provinceId])
  @@map("districts")
}
